@'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebooks
.ipynb_checkpoints/
*.ipynb_meta

# Dados — ignora TUDO em data/, preserva só .gitkeep
data/raw/*
!data/raw/.gitkeep
data/manifests/*
!data/manifests/.gitkeep
data/results/*
!data/results/.gitkeep

# Bancos e dados binários (em qualquer lugar do repo)
*.sqlite
*.sqlite3
*.db
*.parquet

# Credenciais — variantes JSON e outros formatos
credentials*.json
*credentials*.json
secret*.json
service-account*.json
client_secret*.json
*.cred
*.pfx
*.p12

# Playwright
playwright-report/
test-results/
.playwright/
playwright/.cache/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Credenciais / segredos
.env
*.pem
*.key
'@ | Set-Content .gitignore -Encoding utf8

# Confere
type .gitignore
# Resultados de scripts de smoke test (gerados por execu��o manual)
data/smoke_*/
data/tranco_*/

# Dados de execucao do pipeline (coleta piloto, pre-piloto, runs) — regeneraveis,
# nao versionar (tar.gz de evidencias, SQLite, screenshots, logs UTF-16)
data/b4/
data/prepilot/
data/run/

# Scripts temporarios de consulta ad-hoc
_query.py
