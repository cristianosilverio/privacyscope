__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebooks
.ipynb_checkpoints/
*.ipynb_meta

# Dados â€” ignora TUDO em data/, preserva sÃ³ .gitkeep
data/raw/*
!data/raw/.gitkeep
data/manifests/*
!data/manifests/.gitkeep
data/results/*
!data/results/.gitkeep

# Bancos e dados binÃ¡rios (em qualquer lugar do repo)
*.sqlite
*.sqlite3
*.db
*.parquet

# Credenciais â€” variantes JSON e outros formatos
